{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "module": "CommonJS",
    "moduleResolution": "Node",
    "outDir": "dist-electron",
    "rootDir": "electron",
    "noEmit": false,
    "allowImportingTsExtensions": false,
    "jsx": "react-jsx",
    "lib": ["ES2022"],
    "types": ["node"]
  },
  "include": ["electron/**/*"]
}
